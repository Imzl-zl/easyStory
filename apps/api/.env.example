# easyStory API environment template
# Copy this file to apps/api/.env before running the backend.

# Required: JWT signing secret for auth token issue/verify.
EASYSTORY_JWT_SECRET=replace-with-a-long-random-secret

# Required when using Credential Center to create / verify encrypted model credentials.
EASYSTORY_CREDENTIAL_MASTER_KEY=replace-with-a-long-random-master-key

# Optional: override the default local sqlite database.
# Default when omitted: sqlite:///apps/api/.runtime/easystory.db
# EASYSTORY_DATABASE_URL=sqlite:///./.runtime/easystory.db

# Optional: JWT expiry in hours. Default: 24
# EASYSTORY_JWT_EXPIRE_HOURS=24

# Optional: explicit CORS origin allowlist, comma-separated.
# Default when omitted: localhost / 127.0.0.1 on any port.
# EASYSTORY_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Optional: regex override for CORS origin matching.
# EASYSTORY_CORS_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Optional: allow private/local model endpoints such as localhost or RFC1918 addresses.
# Default when omitted: false (public https endpoints only).
# EASYSTORY_ALLOW_PRIVATE_MODEL_ENDPOINTS=false

# Optional: allow insecure public http model endpoints for compatibility testing or controlled proxy setups.
# Default when omitted: false (public endpoints must use https).
# EASYSTORY_ALLOW_INSECURE_PUBLIC_MODEL_ENDPOINTS=false

# Optional: allow private/local MCP endpoints such as localhost or RFC1918 addresses.
# Default when omitted: false (public https endpoints only).
# EASYSTORY_ALLOW_PRIVATE_MCP_ENDPOINTS=false

# Optional: allow insecure public http MCP endpoints for compatibility testing or controlled proxy setups.
# Default when omitted: false (public MCP endpoints must use https).
# EASYSTORY_ALLOW_INSECURE_PUBLIC_MCP_ENDPOINTS=false

# Optional: control-plane admin usernames, comma-separated.
# Required to access /api/v1/config/* and template write APIs.
# Default when omitted: empty list (deny all control-plane write access).
# EASYSTORY_CONFIG_ADMIN_USERNAMES=admin,alice
